# PostgreSQL (Neon) — thay bằng connection string của bạn
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

PORT=5001
NODE_ENV=development

# JWT — dùng chuỗi random mạnh trên production
JWT_SECRET="your-jwt-access-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"

# CORS — domain frontend (Vercel), phân tách bằng dấu phẩy nếu nhiều domain
# Ví dụ: https://wms-xxx.vercel.app,http://localhost:3000
CORS_ORIGIN="http://localhost:3000"

# Email cảnh báo (tùy chọn — Nodemailer)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
ADMIN_ALERT_EMAIL="admin@example.com"

# Gemini AI đề xuất nhập hàng (tùy chọn)
GEMINI_API_KEY="your-gemini-api-key"
